          <div class="text-xs text-gray-400 mb-4">3 modules · 6 heures</div>
          <button onclick="startFormation(3)" class="btn-black w-full text-center">Commencer →</button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-black text-white text-center px-6">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-black tracking-tighter mb-4" style="color:var(--or)">Bundle Quintessence IA</h2>
      <p class="text-gray-400 mb-2">3 formations · 27 heures · 2.7 UEC SOFEDUC</p>
      <p class="text-gray-500 text-sm mb-8">Cloud Run Montréal · SOC2 Type II · Loi 25 · RGPD · AI Act UE</p>
      <a href="https://smith-heffa-paygate.vercel.app" target="_blank" class="btn-gold text-base">Accès complet — 399$ CAD</a>
    </div>
  </section>

  <footer class="bg-black border-t py-10 px-6" style="border-color:var(--or)">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center text-xs font-bold uppercase tracking-widest text-gray-500">
