          <div class="flex justify-between mb-6">
            <span class="bloom-badge">Bloom 3→6 · 0.6 UEC</span>
            <i class="fab fa-google text-2xl text-gray-300"></i>
          </div>
          <h3 class="text-xl font-black tracking-tighter mb-4">Formation 3<br>Productivité Agentique</h3>
          <ul class="text-sm text-gray-600 space-y-2 mb-6">
            <li>✓ Méthode P.T.C.F. exclusive</li>
            <li>✓ Google Workspace for Education</li>
            <li>✓ Automatisation Cloud Native</li>
