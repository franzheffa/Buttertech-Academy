        <div class="text-white font-black text-base tracking-tighter mb-1">BUTTERTECH ACADEMY</div>
        <div style="color:var(--or)">Gemini 3.0 · Montréal · SOFEDUC Agréé</div>
      </div>
      <div class="flex gap-6 mt-6 md:mt-0">
        <span>© 2026 Buttertech Inc.</span>
        <a href="#" class="hover:text-yellow-400">Confidentialité · Loi 25</a>
        <a href="#" class="hover:text-yellow-400">Audit SOFEDUC 2026</a>
      </div>
    </div>
  </footer>
</div>

