<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buttertech Academy | SOFEDUC Agréé · IA Responsable & Loi 25</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    :root { --or: #C9A84C; --or2: #E8C96A; --noir: #0A0A0A; }
    * { box-sizing: border-box; }
    .gold { color: var(--or); }
    .bg-gold { background: var(--or); }
    .border-gold { border-color: var(--or); }
    .btn-gold { background: var(--or); color: #000; font-weight: 900; padding: 14px 40px; border-radius: 4px; text-decoration: none; display: inline-block; letter-spacing: 0.1em; text-transform: uppercase; font-size: 12px; transition: all .2s; cursor: pointer; border: none; }
    .btn-gold:hover { background: var(--or2); }
    .btn-black { background: #000; color: var(--or); font-weight: 900; padding: 14px 40px; border-radius: 4px; text-decoration: none; display: inline-block; letter-spacing: 0.1em; text-transform: uppercase; font-size: 12px; border: 2px solid var(--or); transition: all .2s; cursor: pointer; }
    .btn-black:hover { background: var(--or); color: #000; }
    .page { display: none; }
    .page.active { display: block; }
    .module-card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin-bottom: 12px; cursor: pointer; transition: all .2s; }
    .module-card:hover { border-color: var(--or); box-shadow: 0 2px 12px rgba(201,168,76,.15); }
    .module-card.done { border-color: #1A7A4A; background: #f0fdf4; }
    .quiz-opt { width: 100%; text-align: left; padding: 14px 18px; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 8px; cursor: pointer; background: white; font-size: 14px; transition: all .2s; }
    .quiz-opt:hover { border-color: var(--or); background: #fffbeb; }
    .quiz-opt.selected { border-color: var(--or); background: #fffbeb; font-weight: 600; }
    .quiz-opt.correct { border-color: #1A7A4A; background: #f0fdf4; color: #1A7A4A; font-weight: 700; }
    .quiz-opt.wrong { border-color: #c0392b; background: #fef2f2; color: #c0392b; }
    .progress-bar { height: 6px; background: #e5e7eb; border-radius: 99px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--or); border-radius: 99px; transition: width .4s; }
    .bloom-badge { background: var(--or); color: #000; font-size: 10px; font-weight: 900; padding: 3px 10px; letter-spacing: .1em; text-transform: uppercase; display: inline-block; }
    .nav-tab { padding: 8px 16px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; color: #6b7280; border-bottom: 2px solid transparent; transition: all .2s; }
    .nav-tab.active { color: var(--or); border-bottom-color: var(--or); }
    .sofeduc-header { background: #000; color: var(--or); text-align: center; padding: 8px; font-size: 10px; font-weight: 900; letter-spacing: .3em; text-transform: uppercase; border-bottom: 2px solid var(--or); }
    @media print { .no-print { display: none !important; } }
  </style>
</head>
<body class="bg-white text-gray-900 font-sans">

<!-- ══════════════════════════════════════════════════════
     BARRE SOFEDUC
══════════════════════════════════════════════════════ -->
<div class="sofeduc-header no-print">
  BUTTERTECH ACADEMY · SOFEDUC AGRÉÉ · NVIDIA INCEPTION · GOOGLE FOR EDUCATION · LOI 25 · SOC2 TYPE II
</div>

<!-- ══════════════════════════════════════════════════════
     NAVIGATION
══════════════════════════════════════════════════════ -->
<nav class="sticky top-0 z-50 bg-white border-b-2 border-black no-print" style="border-bottom-color: var(--or);">
  <div class="max-w-6xl mx-auto px-6 py-3 flex justify-between items-center">
    <button onclick="showPage('home')" class="flex items-center gap-2">
      <div class="w-9 h-9 bg-black flex items-center justify-center text-white font-black text-lg">B</div>
      <div>
        <div class="font-black text-lg leading-none tracking-tighter">BUTTERTECH</div>
        <div class="text-xs font-bold tracking-widest" style="color:var(--or)">ACADEMY</div>
      </div>
    </button>
    <div class="hidden md:flex items-center gap-1">
      <button onclick="showPage('home')" class="nav-tab" id="tab-home">Accueil</button>
      <button onclick="showPage('formations')" class="nav-tab" id="tab-formations">Formations</button>
      <button onclick="showPage('lms')" class="nav-tab" id="tab-lms">Mon Espace</button>
      <button onclick="showPage('simulateur')" class="nav-tab" id="tab-simulateur">Simulateur IA</button>
    </div>
    <a href="https://smith-heffa-paygate.vercel.app" target="_blank" class="btn-gold text-xs">399$ · S'inscrire</a>
  </div>
</nav>

