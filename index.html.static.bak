     PAGE : HOME
══════════════════════════════════════════════════════ -->
<div id="page-home" class="page active">
  <!-- Hero -->
  <header class="bg-black text-white py-20 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <div class="inline-block border border-yellow-600 text-yellow-500 text-xs font-black px-4 py-2 tracking-widest uppercase mb-8">
        Leader IA Réglementée · Google & NVIDIA Partner · SOFEDUC Agréé
      </div>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight mb-6" style="font-style:italic">
        L'IA DE CONFIANCE.<br><span style="color:var(--or)">CERTIFIÉE.</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-10">
        NVIDIA Inception · Google for Education · Rigueur académique SOFEDUC · Conformité Loi 25 & RGPD
