          <button onclick="startFormation(1)" class="btn-black w-full text-center">Commencer →</button>
        </div>
        <!-- F2 -->
        <div class="border-2 rounded-lg p-8 shadow-xl scale-105 bg-black text-white" style="border-color:var(--or)">
          <div class="absolute-top"></div>
          <div class="flex justify-between mb-6">
            <span class="bloom-badge">Bloom 2→5 · 0.7 UEC</span>
            <i class="fas fa-shield-halved text-2xl" style="color:var(--or)"></i>
          </div>
          <h3 class="text-xl font-black tracking-tighter mb-4" style="color:var(--or)">Formation 2<br>IA Responsable & Loi 25</h3>
          <ul class="text-sm text-gray-400 space-y-2 mb-6">
            <li>✓ Loi 25 · RGPD · AI Act UE</li>
            <li>✓ Conformité mondiale IA</li>
            <li>✓ Audit SOFEDUC 25 critères</li>
