          </div>
          <div class="text-3xl ml-4">→</div>
        </div>
        <div class="progress-bar mt-3">
          <div class="progress-fill" id="f3-progress" style="width:0%"></div>
        </div>
        <div class="text-xs text-gray-400 mt-1" id="f3-progress-label">0 / 3 modules complétés</div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE : FORMATION 2 (LMS complet)
══════════════════════════════════════════════════════ -->
<div id="page-formation2" class="page">
  <div class="bg-black text-xs font-black tracking-widest uppercase py-2 px-6 no-print" style="color:var(--or)">
    <button onclick="showPage('formations')" class="hover:underline">← Retour</button>
    <span class="mx-3">·</span>
    <span>Formation 2 · BTA-IARG-002 · IA Responsable & Loi 25</span>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-10 flex gap-8">
    <!-- Sidebar -->
    <aside class="w-56 shrink-0 no-print">
      <div class="bg-gray-50 border border-gray-200 rounded p-4 sticky top-20">
        <div class="text-xs font-black uppercase tracking-widest text-gray-500 mb-4">Modules du cours</div>
        <ul class="space-y-1" id="f2-sidebar"></ul>
      </div>
    </aside>

    <!-- Contenu -->
    <section class="flex-1" id="f2-content"></section>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE : MON ESPACE LMS
══════════════════════════════════════════════════════ -->
<div id="page-lms" class="page">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-black tracking-tighter mb-2">Mon Espace Apprenant</h1>
    <p class="text-gray-500 text-sm mb-10">Progression SOFEDUC · Attestations · Sondage d'évaluation</p>

    <div class="grid md:grid-cols-3 gap-4 mb-8">
      <div class="bg-black text-white rounded-lg p-6 text-center border-2" style="border-color:var(--or)">
        <div class="text-4xl font-black" style="color:var(--or)" id="lms-uec">0.0</div>
        <div class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-2">UEC obtenues</div>
      </div>
      <div class="border border-gray-200 rounded-lg p-6 text-center">
        <div class="text-4xl font-black" id="lms-modules">0</div>
        <div class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-2">Modules complétés</div>
      </div>
      <div class="border border-gray-200 rounded-lg p-6 text-center">
        <div class="text-4xl font-black" id="lms-formations">0/3</div>
        <div class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-2">Formations finalisées</div>
      </div>
    </div>

    <div class="space-y-3 mb-8">
      <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
        <span class="font-bold text-sm">Formation 1 — Agents IA Gemini 3.0</span>
        <div class="flex items-center gap-3">
          <div class="progress-bar w-32"><div class="progress-fill" id="lms-f1-bar" style="width:0%"></div></div>
          <span class="text-xs text-gray-500" id="lms-f1-pct">0%</span>
        </div>
      </div>
      <div class="flex items-center justify-between p-4 border-2 rounded-lg" style="border-color:var(--or)">
        <span class="font-bold text-sm">Formation 2 — IA Responsable & Loi 25 ★</span>
        <div class="flex items-center gap-3">
          <div class="progress-bar w-32"><div class="progress-fill" id="lms-f2-bar" style="width:0%"></div></div>
          <span class="text-xs text-gray-500" id="lms-f2-pct">0%</span>
        </div>
      </div>
      <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
        <span class="font-bold text-sm">Formation 3 — Productivité Agentique</span>
        <div class="flex items-center gap-3">
          <div class="progress-bar w-32"><div class="progress-fill" id="lms-f3-bar" style="width:0%"></div></div>
          <span class="text-xs text-gray-500" id="lms-f3-pct">0%</span>
        </div>
      </div>
    </div>

    <div class="flex gap-3 flex-wrap">
      <button onclick="startFormation(2)" class="btn-gold">Reprendre Formation 2 →</button>
      <button onclick="showSondage()" class="btn-black">📋 Sondage SOFEDUC</button>
      <button onclick="showAttestation()" id="btn-attestation" class="btn-black" style="display:none">🏛️ Mon Attestation</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE : SIMULATEUR GEMINI
══════════════════════════════════════════════════════ -->
<div id="page-simulateur" class="page">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-3"><span class="bloom-badge">Gemini 3.0 · Cloud Run MTL · 24ms</span></div>
    <h1 class="text-3xl font-black tracking-tighter mb-2">Simulateur Stratégique IA</h1>
    <p class="text-gray-500 text-sm mb-8">Agent Smith-Heffa · Inférence validée SOC2 Type II · Loi 25</p>

    <div class="border-2 rounded-xl overflow-hidden" style="border-color:var(--or)">
      <div class="bg-black p-6">
        <textarea id="sim-prompt" rows="3" placeholder="Posez votre question stratégique ou défi organisationnel IA..."
          class="w-full bg-gray-900 border border-gray-700 rounded-lg p-4 text-white text-sm focus:outline-none focus:border-yellow-500 resize-none placeholder-gray-500"></textarea>
        <button id="sim-btn" onclick="runSimulator()" class="btn-gold mt-3 w-full text-center">
          ⚡ SIMULER AVEC GEMINI
        </button>
      </div>
      <div class="bg-white p-6">
        <pre id="sim-output" class="whitespace-pre-wrap text-sm text-gray-800 min-h-24 font-mono">Prêt. Entrez votre question ci-dessus.</pre>
      </div>
    </div>
    <p class="text-xs text-gray-400 text-center mt-4 uppercase tracking-widest">Inférence Cloud Run Montréal · northamerica-northeast1 · SOC2 Type II</p>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE : SONDAGE SOFEDUC Norme 10
══════════════════════════════════════════════════════ -->
<div id="page-sondage" class="page">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-3 flex gap-2"><span class="bloom-badge">BTA-IARG-002</span><span class="bloom-badge">Norme SOFEDUC 10</span></div>
    <h1 class="text-2xl font-black tracking-tighter mb-2">Sondage d'Évaluation de la Formation</h1>
    <p class="text-gray-500 text-sm mb-8">Votre retour est confidentiel · Archivé 7 ans · Cloud Run Montréal · SOC2 Type II</p>

    <div id="sondage-form">
      <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-gray-500" id="sondage-progress-label">0 / 8 questions répondues</div>
        <div class="progress-bar w-48"><div class="progress-fill" id="sondage-progress-bar" style="width:0%"></div></div>
      </div>

      <div class="overflow-x-auto rounded border border-gray-200 mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-black text-xs font-bold uppercase tracking-wider">
              <th class="text-left px-4 py-3" style="color:var(--or)">Question</th>
              <th class="px-3 py-3 text-center" style="color:var(--or)">1</th>
              <th class="px-3 py-3 text-center" style="color:var(--or)">2</th>
              <th class="px-3 py-3 text-center" style="color:var(--or)">3</th>
              <th class="px-3 py-3 text-center" style="color:var(--or)">4</th>
              <th class="px-3 py-3 text-center" style="color:var(--or)">5</th>
            </tr>
          </thead>
          <tbody id="sondage-tbody"></tbody>
        </table>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-900 mb-2">Commentaires <span class="text-gray-400 font-normal">(facultatif)</span></label>
        <textarea id="sondage-comment" rows="3" placeholder="Vos suggestions d'amélioration..."
          class="w-full border border-gray-300 rounded px-4 py-3 text-sm focus:outline-none resize-none" style="focus-border-color:var(--or)"></textarea>
      </div>

      <button onclick="submitSondage()" id="sondage-btn" class="btn-gold w-full text-center" disabled>
        SOUMETTRE MON ÉVALUATION
      </button>
    </div>

    <div id="sondage-merci" style="display:none" class="text-center py-12">
      <div class="w-16 h-16 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 text-black" style="background:var(--or)">✓</div>
      <h2 class="text-xl font-black mb-2">Merci pour votre retour !</h2>
      <p class="text-gray-500 text-sm mb-2">Score moyen : <strong id="sondage-score" style="color:var(--or)">—/5</strong></p>
      <p class="text-xs text-gray-400 mb-8">Archivé · Cloud Run Montréal · Norme SOFEDUC 10</p>
      <button onclick="showAttestation()" class="btn-gold">🏛️ Obtenir mon attestation SOFEDUC</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     PAGE : ATTESTATION (print-ready)
══════════════════════════════════════════════════════ -->
<div id="page-attestation" class="page">
  <div class="max-w-3xl mx-auto px-6 py-6 no-print flex justify-between items-center">
    <button onclick="showPage('lms')" class="text-sm text-gray-500 hover:text-black">← Mon Espace</button>
    <button onclick="window.print()" class="btn-gold">🖨️ Imprimer / Sauvegarder PDF</button>
  </div>
  <div class="max-w-3xl mx-auto px-6 pb-10">
    <div class="border-4 p-1" style="border-color:var(--or)">
      <div class="border p-8" style="border-color:#F5E6B0">
        <!-- En-tête -->
        <div class="bg-black text-center py-3 mb-8">
          <p class="text-xs font-black tracking-widest uppercase" style="color:var(--or)">
            BUTTERTECH ACADEMY · SOFEDUC AGRÉÉ · NVIDIA INCEPTION · GOOGLE FOR EDUCATION
          </p>
        </div>
        <div class="text-center mb-8">
          <p class="text-xs font-black tracking-widest uppercase mb-2" style="color:var(--or)">ATTESTATION DE RÉUSSITE</p>
          <div class="w-20 h-0.5 mx-auto mb-4" style="background:var(--or)"></div>
          <p class="text-gray-500 italic mb-4 text-sm">La présente atteste que</p>
          <div class="border-b-2 mx-8 pb-1 mb-4" style="border-color:var(--or)">
            <p class="text-2xl font-black" style="font-style:italic" id="attest-nom">[ Prénom NOM ]</p>
          </div>
          <p class="text-gray-500 italic mb-3 text-sm">a complété avec succès la formation</p>
          <p class="text-2xl font-black tracking-tighter mb-1">Formation 2 — IA Responsable & Loi 25</p>
          <p class="text-gray-500 italic text-sm mb-6">Conformité & Gouvernance Mondiale de l'Intelligence Artificielle</p>

          <div class="grid grid-cols-4 gap-4 mb-8 text-center">
            <div><p class="text-xs font-black uppercase tracking-widest" style="color:var(--or)">DURÉE</p><p class="text-sm mt-1">7h · 5 modules</p></div>
            <div><p class="text-xs font-black uppercase tracking-widest" style="color:var(--or)">UEC SOFEDUC</p><p class="text-sm mt-1">0.7 UEC</p></div>
            <div><p class="text-xs font-black uppercase tracking-widest" style="color:var(--or)">BLOOM</p><p class="text-sm mt-1">Analyser → Évaluer</p></div>
            <div><p class="text-xs font-black uppercase tracking-widest" style="color:var(--or)">DATE</p><p class="text-sm mt-1" id="attest-date">—</p></div>
          </div>

          <div class="grid grid-cols-2 gap-12 px-8 mb-6">
            <div class="text-center"><div class="border-b border-gray-400 h-8 mb-1"></div><p class="text-xs text-gray-500">Directeur de Formation · ButterTech Academy</p></div>
            <div class="text-center"><div class="border-b border-gray-400 h-8 mb-1"></div><p class="text-xs text-gray-500">Responsable Accréditation · SOFEDUC</p></div>
          </div>

          <p class="text-xs text-gray-400" id="attest-num">N° BTA-IARG-002-XXXX · buttertech-academy.vercel.app/verify · Archivé 7 ans · SOC2 Type II</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     JAVASCRIPT — LMS + Quiz + Simulateur
══════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  // ── État global ────────────────────────────────────────
  const STATE = {
    f1: { done: [], total: 6 },
    f2: { done: [], total: 5 },
    f3: { done: [], total: 3 },
    currentF2Module: 0,
    quizAnswers: {},
    quizSubmitted: false,
    sondageAnswers: {},
    nomApprenant: 'Prénom NOM'
  };

  // ── Données Formation 2 ────────────────────────────────
  const F2_MODULES = [
    {
      id: 1, slug: 'module1', titre: 'Loi 25 — Principes Fondamentaux au Québec',
      bloom: 'COMPRENDRE (2)', duree: '1h30',
      intro: `La Loi 25 (Loi modernisant des dispositions législatives en matière de protection des renseignements personnels) est en vigueur depuis septembre 2023 au Québec. Elle impose des obligations strictes aux organisations qui collectent et traitent des données personnelles, incluant les plateformes de formation en ligne.`,
      points: [
        'Consentement explicite et éclairé requis avant toute collecte de données',
        'Droit d\'accès, de rectification et de retrait du consentement (tout apprenant)',
        'Nomination obligatoire d\'un Responsable de la Protection des Renseignements Personnels (RPP)',
        'Déclaration des incidents de confidentialité à la Commission d\'accès à l\'information (CAI)',
        'Évaluation des facteurs relatifs à la vie privée (EFVP) avant tout nouveau traitement à risque',
      ],
      quiz: {
        q: 'Selon la Loi 25, dans quel délai maximum une organisation doit-elle répondre à une demande d\'accès aux données personnelles ?',
        opts: ['15 jours calendaires', '30 jours calendaires', '60 jours calendaires', '72 heures'],
        correct: 1,
        explication: 'La Loi 25 prévoit un délai de 30 jours pour répondre à toute demande d\'accès, de rectification ou de retrait du consentement.'
      }
    },
    {
      id: 2, slug: 'module2', titre: 'RGPD & Équivalences Mondiales',
      bloom: 'COMPRENDRE (2)', duree: '1h30',
      intro: `Le RGPD (Règlement Général sur la Protection des Données) est entré en vigueur le 25 mai 2018 dans l'Union Européenne et constitue le cadre de référence mondial. La Loi 25 s'en inspire directement tout en intégrant des spécificités propres au contexte juridique canadien.`,
      points: [
        'RGPD EU : autorité CNIL/EDPB · sanctions jusqu\'à 20M€ ou 4% CA mondial',
        'Loi 25 QC : autorité CAI · sanctions jusqu\'à 25M$ CAD ou 4% CA',
        'UK-GDPR : post-Brexit · autorité ICO · 72h notification obligatoire',
        'LGPD Brésil : autorité ANPD · inspiré du RGPD · base légale obligatoire',
        'CCPA Californie : droits des consommateurs · pas de loi fédérale US unifiée',
      ],
      quiz: {
        q: 'Selon le RGPD EU (Art. 33), dans quel délai une violation de données doit-elle être notifiée à l\'autorité de contrôle compétente ?',
        opts: ['24 heures', '48 heures', '72 heures', '7 jours calendaires'],
        correct: 2,
        explication: 'L\'Art. 33 du RGPD impose une notification dans les 72 heures suivant la prise de connaissance de la violation, sauf si elle ne présente pas de risque pour les personnes.'
      }
    },
    {
      id: 3, slug: 'module3', titre: 'AI Act UE — Classification par Niveaux de Risque',
      bloom: 'ANALYSER (4)', duree: '1h30',
      intro: `L'AI Act UE est le premier règlement mondial sur l'intelligence artificielle. Entré en vigueur en août 2024, il adopte une approche basée sur les risques : plus un système IA présente de risques pour les droits fondamentaux, plus les obligations réglementaires sont strictes.`,
      points: [
        '🚫 Risque INACCEPTABLE : interdit · score social, manipulation subliminale · sanctions 35M€ / 7% CA',
        '⚠️ Risque ÉLEVÉ : éducation, emploi, infrastructure critique · audit tiers obligatoire · Registre EU',
        '⚡ Risque LIMITÉ : chatbots, deepfakes · obligation de transparence envers les utilisateurs',
        '✅ Risque MINIMAL : spam, recommandation, traduction · aucune obligation spécifique',
        'Application progressive : 2024 (interdictions) → 2025 (risque élevé) → 2027 (complet)',
      ],
      quiz: {
        q: 'Selon l\'AI Act UE, un système IA utilisé pour le recrutement et la sélection de personnel est classifié à quel niveau de risque ?',
        opts: ['Risque minimal', 'Risque limité', 'Risque élevé', 'Risque inacceptable'],
        correct: 2,
        explication: 'Les systèmes IA utilisés en emploi (tri de CV, entretiens automatisés, évaluation candidats) sont "risque élevé" car ils affectent des droits fondamentaux liés au travail.'
      }
    },
    {
      id: 4, slug: 'module4', titre: 'Déploiement Cloud Conforme — Privacy by Design',
      bloom: 'ANALYSER (4)', duree: '1h30',
      intro: `Le déploiement d'une IA conforme commence par le choix de l'infrastructure. Cloud Run Montréal (northamerica-northeast1) garantit la résidence des données au Canada, satisfaisant ainsi la Loi 25, avec une certification SOC2 Type II et une latence P95 de 24ms mesurée en production.`,
      points: [
        'Privacy by Design : intégrer la protection des données dès la conception, pas après',
        'Cloud Run MTL : northamerica-northeast1 · données 100% Canada · SOC2 Type II · 24ms P95',
        'Chiffrement : AES-256 au repos · TLS 1.3 en transit · Secret Manager pour les clés',
        'Journalisation : Cloud Logs 7 ans (SOFEDUC & Loi 25) · traçabilité complète',
        'EFVP obligatoire avant tout nouveau traitement IA présentant un risque sérieux',
      ],
      quiz: {
        q: 'Quelle région Google Cloud garantit la résidence des données au Canada (Loi 25) avec SOC2 Type II ?',
        opts: ['us-central1 (Iowa)', 'northamerica-northeast1 (Montréal)', 'northamerica-northeast2 (Toronto)', 'europe-west1 (Belgique)'],
        correct: 1,
        explication: 'northamerica-northeast1 = Montréal. Données 100% au Canada, SOC2 Type II, latence P95 à 24ms en production BTA.'
      }
    },
    {
      id: 5, slug: 'module5', titre: 'Audit SOFEDUC & Certification',
      bloom: 'ÉVALUER ★ (5)', duree: '1h00',
      intro: `La certification SOFEDUC repose sur la validation de 25 critères répartis en 5 catégories. Le quiz final de 20 questions (seuil 70%) permet d'obtenir l'attestation de réussite avec 0.7 UEC, archivée 7 ans sur Cloud Run Montréal conformément à la Loi 25 et aux normes SOFEDUC.`,
      points: [
        'A. Gouvernance & RPP : nomination RPP, politique de gouvernance, registre des traitements',
        'B. Consentement & Droits : formulaires conformes, retrait actif, portabilité, désindexation',
        'C. Sécurité Technique : AES-256, TLS 1.3, MFA, tests de pénétration, journalisation 7 ans',
        'D. IA & Algorithmes : inventaire IA, évaluation AI Act, transparence, audit biais, supervision humaine',
        'E. Conformité & Audit : EFVP, contrats sous-traitants, certification SOFEDUC, rapport annuel',
      ],
      quiz: null, // → Quiz final 20 questions
      isFinal: true
    }
  ];

  const QUIZ_FINAL = [
    { q: 'Depuis quelle date la Loi 25 est-elle pleinement en vigueur au Québec ?', opts: ['Septembre 2022', 'Septembre 2023', 'Septembre 2024', 'Janvier 2024'], c: 1 },
    { q: 'Quelle est la durée de conservation obligatoire des données de formation selon SOFEDUC ?', opts: ['3 ans', '5 ans', '7 ans', '10 ans'], c: 2 },
    { q: 'L\'AI Act UE interdit catégoriquement quel type de système IA ?', opts: ['Les chatbots', 'Le score social par les autorités publiques', 'La recommandation de contenu', 'La traduction automatique'], c: 1 },
    { q: 'Quelle est la sanction maximale pour violation grave de la Loi 25 ?', opts: ['1M$ CAD', '10M$ CAD', '25M$ CAD ou 4% CA', '50M$ CAD'], c: 2 },
    { q: 'L\'EFVP est obligatoire dans quel contexte selon la Loi 25 ?', opts: ['Tout nouveau site web', 'Tout traitement susceptible de présenter un risque sérieux', 'Uniquement pour les grandes entreprises', 'Seulement pour les données de santé'], c: 1 },
    { q: 'Quelle région Google Cloud garantit la résidence des données au Canada ?', opts: ['us-east1', 'northamerica-northeast1', 'europe-west3', 'asia-east1'], c: 1 },
    { q: 'Le principe "Privacy by Design" signifie :', opts: ['Chiffrer les données après déploiement', 'Intégrer la protection des données dès la conception', 'Nommer un DPO externe', 'Utiliser uniquement des serveurs canadiens'], c: 1 },
    { q: 'Combien de normes SOFEDUC doit respecter une formation pour l\'accréditation ?', opts: ['5', '7', '8', '10'], c: 3 },
    { q: 'Dans quel délai une violation de données doit-elle être notifiée à l\'ICO (Royaume-Uni) ?', opts: ['24h', '48h', '72h', '7 jours'], c: 2 },
    { q: 'Quelle loi brésilienne équivaut au RGPD ?', opts: ['CCPA', 'PDPA', 'LGPD', 'PIPL'], c: 2 },
    { q: 'Le RPP nommé selon la Loi 25 doit :', opts: ['Être un avocat externe', 'Voir son nom publié sur le site de l\'organisation', 'Être certifié CIPP/C obligatoirement', 'Être un employé de la CAI'], c: 1 },
    { q: 'Quel protocole de chiffrement est requis pour les communications ?', opts: ['SSL 3.0', 'TLS 1.0', 'TLS 1.2', 'TLS 1.3'], c: 3 },
    { q: 'L\'AI Act prévoit des sanctions allant jusqu\'à quelle somme pour les violations graves ?', opts: ['10M€ ou 2% CA', '20M€ ou 4% CA', '35M€ ou 7% CA', '50M€ ou 10% CA'], c: 2 },
    { q: 'Quelle est la définition d\'un incident de confidentialité selon la Loi 25 ?', opts: ['Toute erreur informatique', 'Accès, utilisation, divulgation, copie ou modification non autorisés', 'Uniquement le vol de données', 'Une erreur d\'employé seulement'], c: 1 },
    { q: 'Le CCPA s\'applique dans quel état américain ?', opts: ['New York', 'Texas', 'Floride', 'Californie'], c: 3 },
    { q: 'Quel outil Google Cloud stocke les secrets (clés API) de façon sécurisée ?', opts: ['Cloud Storage', 'Firestore', 'Secret Manager', 'Cloud SQL'], c: 2 },
    { q: 'Quel est le seuil de réussite minimum pour l\'attestation SOFEDUC ?', opts: ['60%', '65%', '70%', '80%'], c: 2 },
    { q: 'Quelle certification de sécurité est obtenue par Cloud Run Montréal ?', opts: ['ISO 27001 seulement', 'SOC1 Type I', 'SOC2 Type II', 'PCI-DSS Level 1'], c: 2 },
    { q: 'L\'AI Act UE classe les systèmes IA de recrutement à quel niveau ?', opts: ['Risque minimal', 'Risque limité', 'Risque élevé', 'Risque inacceptable'], c: 2 },
    { q: 'Combien de critères comporte la checklist d\'audit SOFEDUC pour la certification IA ?', opts: ['10 critères', '15 critères', '20 critères', '25 critères'], c: 3 },
  ];

  const SONDAGE_QUESTIONS = [
    'Les objectifs de la formation ont été clairement présentés',
    'Le contenu était adapté à mon niveau et mes besoins professionnels',
    'Les exemples et cas pratiques étaient pertinents et applicables',
    'Le formateur / la plateforme a facilité l\'apprentissage efficacement',
    'La durée de la formation était appropriée au contenu',
    'L\'évaluation (quiz) reflétait bien les apprentissages',
    'Je recommanderais cette formation à un collègue',
    'Cette formation a renforcé ma compréhension de la conformité IA',
  ];

  // ── Navigation ─────────────────────────────────────────
  window.showPage = function(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
    const p = document.getElementById('page-' + name);
    if (p) p.classList.add('active');
    const t = document.getElementById('tab-' + name);
    if (t) t.classList.add('active');
    if (name === 'lms') updateLMS();
    if (name === 'formations') updateFormationsProgress();
    window.scrollTo(0, 0);
  };

  // ── Formation 2 ────────────────────────────────────────
  window.startFormation = function(num) {
    if (num === 2) {
      renderF2(STATE.currentF2Module);
      showPage('formation2');
    } else {
      alert('Formation ' + num + ' disponible avec le Bundle Quintessence — buttertech-academy.vercel.app');
    }
  };

  function renderF2(moduleIndex) {
    STATE.currentF2Module = moduleIndex;
    const mod = F2_MODULES[moduleIndex];
    if (!mod) return;

    // Sidebar
    const sidebar = document.getElementById('f2-sidebar');
    if (sidebar) {
      sidebar.innerHTML = F2_MODULES.map((m, i) => `
        <li>
          <button onclick="renderF2(${i})"
            class="w-full text-left flex items-center gap-2 py-1.5 px-2 rounded text-sm transition-all ${i === moduleIndex ? 'font-bold' : 'text-gray-600 hover:text-black'}"
            style="${i === moduleIndex ? 'color:var(--or)' : ''}">
            <span class="w-4 h-4 rounded-full border-2 flex items-center justify-center text-xs shrink-0
              ${STATE.f2.done.includes(i) ? 'bg-green-500 border-green-500 text-white' : i === moduleIndex ? 'border-yellow-500' : 'border-gray-300'}">
              ${STATE.f2.done.includes(i) ? '✓' : ''}
            </span>
            <span>${m.titre.split(' — ')[0].replace('Module ', '').slice(0, 28)}...</span>
          </button>
        </li>
      `).join('');
    }

    // Contenu
    const content = document.getElementById('f2-content');
    if (!content) return;

    if (mod.isFinal) {
      renderFinalQuiz(content, mod, moduleIndex);
    } else {
      renderModule(content, mod, moduleIndex);
    }
  }

  function renderModule(content, mod, moduleIndex) {
    const done = STATE.f2.done.includes(moduleIndex);
    content.innerHTML = `
      <div class="mb-3 flex gap-2 flex-wrap">
        <span class="bloom-badge">Formation 2 · Module ${mod.id}/5</span>
        <span class="bloom-badge" style="background:#000;color:var(--or)">${mod.bloom}</span>
      </div>
      <h1 class="text-2xl font-black tracking-tighter mb-1">${mod.titre}</h1>
      <p class="text-sm mb-6" style="color:var(--or);font-weight:700">Durée estimée : ${mod.duree}</p>

      <div class="bg-black text-white rounded p-5 mb-5 flex items-center justify-center" style="min-height:160px">
        <div class="text-center">
          <div class="w-12 h-12 border-2 rounded-full flex items-center justify-center mx-auto mb-3 cursor-pointer hover:opacity-80" style="border-color:var(--or)">
            <span style="color:var(--or);font-size:20px">▶</span>
          </div>
          <p class="text-gray-400 text-xs">Vidéo · ${mod.duree} · Cloud Run Montréal · SOC2 Type II</p>
        </div>
      </div>

      <div class="border border-gray-200 rounded p-5 mb-5">
        <p class="text-gray-800 text-sm leading-relaxed mb-4">${mod.intro}</p>
        <ul class="space-y-2">
          ${mod.points.map(p => `<li class="flex items-start gap-2 text-sm text-gray-700"><span style="color:var(--or);margin-top:2px">•</span>${p}</li>`).join('')}
        </ul>
      </div>

      ${mod.quiz ? renderQuizBlock(mod.quiz, moduleIndex) : ''}
    `;

    if (mod.quiz) setupQuiz(mod.quiz, moduleIndex);
  }

  function renderQuizBlock(quiz, moduleIndex) {
    return `
      <div class="border-2 rounded p-6" style="border-color:var(--or)">
        <h2 class="font-black text-lg mb-1" style="color:var(--or)">☑ ÉVALUATION FORMATIVE</h2>
        <p class="font-bold mb-4 text-sm text-gray-900">${quiz.q}</p>
        <div id="quiz-opts-${moduleIndex}" class="mb-4">
          ${quiz.opts.map((o, i) => `
            <button class="quiz-opt" data-idx="${i}" onclick="selectQuizOpt(${moduleIndex}, ${i})">${o}</button>
          `).join('')}
        </div>
        <div id="quiz-actions-${moduleIndex}">
          <button onclick="submitQuiz(${moduleIndex})" id="quiz-btn-${moduleIndex}" class="btn-gold" disabled>VALIDER MA RÉPONSE</button>
        </div>
        <div id="quiz-result-${moduleIndex}" style="display:none" class="mt-4"></div>
      </div>
    `;
  }

  function setupQuiz(quiz, moduleIndex) {
    STATE.quizAnswers[moduleIndex] = null;
    STATE.quizSubmitted = false;
  }

  window.selectQuizOpt = function(modIdx, optIdx) {
    if (STATE.f2.done.includes(modIdx)) return;
    STATE.quizAnswers[modIdx] = optIdx;
    document.querySelectorAll(`#quiz-opts-${modIdx} .quiz-opt`).forEach((btn, i) => {
      btn.classList.toggle('selected', i === optIdx);
    });
    const submitBtn = document.getElementById(`quiz-btn-${modIdx}`);
    if (submitBtn) submitBtn.disabled = false;
  };

  window.submitQuiz = function(modIdx) {
    const mod = F2_MODULES[modIdx];
    const selected = STATE.quizAnswers[modIdx];
    if (selected === null || selected === undefined) return;
    const correct = mod.quiz.correct;
    const isCorrect = selected === correct;

    document.querySelectorAll(`#quiz-opts-${modIdx} .quiz-opt`).forEach((btn, i) => {
      btn.disabled = true;
      if (i === correct) btn.classList.add('correct');
      if (i === selected && !isCorrect) btn.classList.add('wrong');
    });

    const resultEl = document.getElementById(`quiz-result-${modIdx}`);
    if (resultEl) {
      resultEl.style.display = 'block';
      resultEl.innerHTML = `
        <div class="rounded p-3 text-sm font-bold mb-3 ${isCorrect ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200'}">
          ${isCorrect ? '✅ Excellent !' : '❌ Bonne réponse : ' + mod.quiz.opts[correct]}
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded p-3 text-xs text-gray-600 italic mb-4">💡 ${mod.quiz.explication}</div>
        ${modIdx < F2_MODULES.length - 1
          ? `<button onclick="renderF2(${modIdx + 1})" class="btn-gold">→ MODULE SUIVANT</button>`
          : `<button onclick="renderF2(${modIdx + 1})" class="btn-gold">→ QUIZ FINAL</button>`}
      `;
    }

    const btnEl = document.getElementById(`quiz-btn-${modIdx}`);
    if (btnEl) btnEl.style.display = 'none';

    if (!STATE.f2.done.includes(modIdx)) {
      STATE.f2.done.push(modIdx);
      updateLMS();
    }
  };

  // ── Quiz Final Formation 2 ─────────────────────────────
  function renderFinalQuiz(content, mod, moduleIndex) {
    let answered = {};
    let submitted = false;

    const renderQ = () => {
      const answeredCount = Object.keys(answered).length;
      content.innerHTML = `
        <div class="mb-3 flex gap-2"><span class="bloom-badge">Module 5/5 · Quiz Final</span><span class="bloom-badge" style="background:#000;color:var(--or)">ÉVALUER ★ (5)</span></div>
        <h1 class="text-2xl font-black tracking-tighter mb-1">${mod.titre}</h1>
        <p class="text-sm mb-4 font-bold" style="color:var(--or)">20 questions · Seuil 70% · Attestation SOFEDUC à l'issue</p>

        <div class="border-2 rounded p-6 mb-4" style="border-color:var(--or)">
          <p class="text-sm text-gray-600 mb-6">${mod.intro}</p>
          <ul class="space-y-2 mb-6">
            ${mod.points.map(p => `<li class="flex items-start gap-2 text-sm text-gray-700"><span style="color:var(--or);margin-top:2px">•</span>${p}</li>`).join('')}
          </ul>
        </div>

        <div class="border-2 rounded p-6" style="border-color:var(--or)">
          <h2 class="font-black text-lg mb-1" style="color:var(--or)">☑ QUIZ FINAL — 20 QUESTIONS</h2>
          <p class="text-xs text-gray-500 mb-6">${answeredCount}/20 questions répondues</p>
          <div class="progress-bar mb-6"><div class="progress-fill" style="width:${answeredCount/20*100}%"></div></div>
          <div class="space-y-6" id="final-quiz-container">
            ${QUIZ_FINAL.map((q, qi) => `
              <div>
                <p class="font-bold text-sm mb-2"><span style="color:var(--or)">Q${qi+1}.</span> ${q.q}</p>
                <div class="space-y-2">
                  ${q.opts.map((o, oi) => `
                    <button onclick="selectFinal(${qi},${oi})" data-q="${qi}" data-o="${oi}"
                      class="quiz-opt ${answered[qi]===oi ? 'selected' : ''}">
                      ${o}
                    </button>
                  `).join('')}
                </div>
              </div>
            `).join('')}
          </div>
          <div class="mt-6 text-center text-xs text-gray-400 mb-3">${answeredCount}/20 questions répondues</div>
          <button onclick="submitFinalQuiz()" id="final-submit-btn" class="btn-gold w-full text-center" ${answeredCount<20?'disabled':''}>
            SOUMETTRE LE QUIZ FINAL
          </button>
        </div>
      `;

      window.selectFinal = function(qi, oi) {
        answered[qi] = oi;
        renderQ();
        window.scrollTo(0, document.getElementById('final-quiz-container') ? document.getElementById('final-quiz-container').getBoundingClientRect().top + window.scrollY - 100 : 0);
      };

      window.submitFinalQuiz = function() {
        const score = QUIZ_FINAL.filter((q, i) => answered[i] === q.c).length;
        const pct = Math.round(score / QUIZ_FINAL.length * 100);
        const passed = pct >= 70;

        if (passed && !STATE.f2.done.includes(moduleIndex)) {
          STATE.f2.done.push(moduleIndex);
          updateLMS();
        }

        content.innerHTML = `
          <div class="text-center py-12">
            <div class="w-20 h-20 rounded-full flex items-center justify-center text-4xl mx-auto mb-6 font-black
              ${passed ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
              ${passed ? '��' : '📚'}
            </div>
            <div class="text-5xl font-black mb-2 ${passed ? 'text-green-700' : 'text-red-600'}">${pct}%</div>
            <p class="font-black text-lg mb-2 ${passed ? 'text-green-700' : 'text-red-600'}">
              ${passed ? '✅ RÉUSSITE — Attestation SOFEDUC délivrée' : '⚠️ Score insuffisant — Minimum requis : 70%'}
            </p>
            <p class="text-sm text-gray-500 mb-8">${score}/20 bonnes réponses</p>
            ${passed
              ? `<div class="flex gap-3 justify-center flex-wrap">
                   <button onclick="showSondage()" class="btn-gold">📋 Sondage SOFEDUC →</button>
                   <button onclick="showAttestation()" class="btn-black">🏛️ Mon Attestation</button>
                 </div>`
              : `<button onclick="renderF2(${moduleIndex})" class="btn-black">🔄 Reprendre le quiz</button>`
            }
          </div>
        `;
      };
    };

    renderQ();
  }

  // ── LMS Update ─────────────────────────────────────────
  function updateLMS() {
    const f2pct = Math.round(STATE.f2.done.length / STATE.f2.total * 100);
    const totalModules = STATE.f1.done.length + STATE.f2.done.length + STATE.f3.done.length;
    const totalMax = STATE.f1.total + STATE.f2.total + STATE.f3.total;
    const uec = ((STATE.f2.done.length / STATE.f2.total) * 0.7).toFixed(1);

    const el = (id) => document.getElementById(id);
    if (el('lms-uec')) el('lms-uec').textContent = uec;
    if (el('lms-modules')) el('lms-modules').textContent = totalModules;
    if (el('lms-f2-bar')) el('lms-f2-bar').style.width = f2pct + '%';
    if (el('lms-f2-pct')) el('lms-f2-pct').textContent = f2pct + '%';
    if (el('lms-f1-bar')) el('lms-f1-bar').style.width = '0%';
    if (el('lms-f3-bar')) el('lms-f3-bar').style.width = '0%';

    const formations = [
      STATE.f1.done.length === STATE.f1.total,
      STATE.f2.done.length === STATE.f2.total,
      STATE.f3.done.length === STATE.f3.total,
    ].filter(Boolean).length;
    if (el('lms-formations')) el('lms-formations').textContent = formations + '/3';

    if (STATE.f2.done.length === STATE.f2.total) {
      const btnAttest = el('btn-attestation');
      if (btnAttest) btnAttest.style.display = 'inline-block';
    }
  }

  function updateFormationsProgress() {
    const f2pct = Math.round(STATE.f2.done.length / STATE.f2.total * 100);
    const el = (id) => document.getElementById(id);
    if (el('f2-progress')) el('f2-progress').style.width = f2pct + '%';
    if (el('f2-progress-label')) el('f2-progress-label').textContent = STATE.f2.done.length + ' / 5 modules complétés';
  }

  // ── Sondage ────────────────────────────────────────────
  window.showSondage = function() {
    renderSondage();
    showPage('sondage');
  };

  function renderSondage() {
    const tbody = document.getElementById('sondage-tbody');
    if (!tbody) return;
    tbody.innerHTML = SONDAGE_QUESTIONS.map((q, qi) => `
      <tr class="${qi%2===0?'bg-white':'bg-gray-50'}">
        <td class="px-4 py-3 text-sm text-gray-800"><span class="font-bold" style="color:var(--or)">Q${qi+1}</span> ${q}</td>
        ${[1,2,3,4,5].map(v => `
          <td class="px-3 py-3 text-center">
            <button onclick="selectSondage(${qi},${v})" id="s-${qi}-${v}"
              class="w-7 h-7 rounded-full border-2 transition-all ${STATE.sondageAnswers[qi]===v?'bg-yellow-500 border-yellow-500':'border-gray-300 hover:border-yellow-400'}"
              style="${STATE.sondageAnswers[qi]===v?'background:var(--or);border-color:var(--or)':''}">
            </button>
          </td>
        `).join('')}
      </tr>
    `).join('');
    updateSondageProgress();
  }

  window.selectSondage = function(qi, val) {
    STATE.sondageAnswers[qi] = val;
    renderSondage();
  };

  function updateSondageProgress() {
    const count = Object.keys(STATE.sondageAnswers).length;
    const pct = Math.round(count / SONDAGE_QUESTIONS.length * 100);
    const el = (id) => document.getElementById(id);
    if (el('sondage-progress-label')) el('sondage-progress-label').textContent = count + ' / ' + SONDAGE_QUESTIONS.length + ' questions répondues';
    if (el('sondage-progress-bar')) el('sondage-progress-bar').style.width = pct + '%';
    const btn = el('sondage-btn');
    if (btn) btn.disabled = count < SONDAGE_QUESTIONS.length;
  }

  window.submitSondage = function() {
    const vals = Object.values(STATE.sondageAnswers);
    const avg = (vals.reduce((a,b)=>a+b,0) / vals.length).toFixed(1);
    document.getElementById('sondage-form').style.display = 'none';
    document.getElementById('sondage-merci').style.display = 'block';
    document.getElementById('sondage-score').textContent = avg + '/5';
  };

  // ── Attestation ────────────────────────────────────────
  window.showAttestation = function() {
    const nom = prompt('Entrez votre nom complet pour l\'attestation :') || 'Prénom NOM';
    STATE.nomApprenant = nom;
    const num = 'BTA-IARG-002-' + Math.random().toString(36).slice(2,8).toUpperCase();
    const now = new Date().toLocaleDateString('fr-CA', {year:'numeric',month:'long',day:'numeric'});
    const el = (id) => document.getElementById(id);
    if (el('attest-nom')) el('attest-nom').textContent = nom;
    if (el('attest-date')) el('attest-date').textContent = now;
    if (el('attest-num')) el('attest-num').textContent = 'N° ' + num + ' · buttertech-academy.vercel.app/verify · Archivé 7 ans · SOC2 Type II';
    showPage('attestation');
  };

  // ── Simulateur Gemini ──────────────────────────────────
  window.runSimulator = function() {
    const prompt = (document.getElementById('sim-prompt') || {}).value || '';
    const out = document.getElementById('sim-output');
    const btn = document.getElementById('sim-btn');
    if (!prompt.trim()) return;
    if (btn) btn.disabled = true;
    if (out) out.textContent = 'Analyse en cours...';
    fetch('/api/gemini', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, system: 'Tu es Agent Smith-Heffa, expert IA et conformité SOFEDUC. Réponse structurée, concise, en français.' })
    })
    .then(r => r.json())
    .then(d => { if (out) out.textContent = (d.mode==='live'?'[LIVE]\n\n':'[DEMO]\n\n') + (d.text||''); })
    .catch(() => { if (out) out.textContent = '[ERREUR] Gemini indisponible.'; })
    .finally(() => { if (btn) btn.disabled = false; });
  };

  // ── Init ───────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    renderSondage();
    showPage('home');
  });

})();
</script>

</body>
</html>
