      <p class="text-center text-gray-500 mb-14 text-sm">Taxonomie de Bloom · Session Mars 2026</p>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- F1 -->
        <div class="border border-gray-200 rounded-lg p-8 hover:border-yellow-500 hover:shadow-lg transition-all">
          <div class="flex justify-between mb-6">
            <span class="bloom-badge">Bloom 1→6 · 0.6 UEC</span>
