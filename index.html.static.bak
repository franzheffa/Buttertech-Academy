        <button onclick="showPage('formations')" class="btn-gold text-sm">Voir les formations →</button>
        <a href="https://smith-heffa-paygate.vercel.app" target="_blank" class="btn-black text-sm">Bundle Quintessence 399$</a>
      </div>
    </div>
  </header>

  <!-- Stats -->
  <section class="py-12 bg-black border-t-2" style="border-color:var(--or)">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div><div class="text-3xl font-black" style="color:var(--or)">3</div><div class="text-gray-400 text-xs font-bold tracking-widest uppercase mt-1">Formations SOFEDUC</div></div>
      <div><div class="text-3xl font-black" style="color:var(--or)">2.7</div><div class="text-gray-400 text-xs font-bold tracking-widest uppercase mt-1">UEC Certifiées</div></div>
      <div><div class="text-3xl font-black" style="color:var(--or)">24ms</div><div class="text-gray-400 text-xs font-bold tracking-widest uppercase mt-1">Cloud Run Montréal</div></div>
